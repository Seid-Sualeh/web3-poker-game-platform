# Production Environment Variables
# Copy this file to .env.production and fill in your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=production
PORT=10000

# ===========================================
# MONGODB ATLAS CONFIGURATION
# ===========================================
# Replace the angle brackets and placeholder with your actual MongoDB Atlas credentials
# Format: mongodb+srv://<username>:<password>@cluster<cluster-id>..mongodb.net/<database-name>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<your-username>:<your-password>@cluster<cluster-id>..mongodb.net/poker-game?retryWrites=true&w=majority

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate a strong random string for JWT_SECRET (use openssl rand -base64 32)
JWT_SECRET=<your-secure-jwt-secret-min-32-chars>

# ===========================================
# WEB3 / BLOCKCHAIN CONFIGURATION
# ===========================================
# Get your free API key from https://www.alchemy.com/
ALCHEMY_API_KEY=<your-alchemy-api-key>

# Get free RPC URLs from https://www.infura.io/ or use public ones
WEB3_PROVIDER_URL=https://eth-mainnet.alchemyapi.io/v2/<your-alchemy-api-key>

# Polygon RPC (can use https://polygon-rpc.com for free)
POLYGON_RPC_URL=https://polygon-rpc.com

# Get free API keys from https://etherscan.io/ and https://polygonscan.com/
ETHERSCAN_API_KEY=<your-etherscan-api-key>
POLYGONSCAN_API_KEY=<your-polygonscan-api-key>

# ===========================================
# IPFS STORAGE (Optional - for NFT metadata)
# ===========================================
# Get credentials from https://www.infura.io/product/ipfs
INFURA_IPFS_PROJECT_ID=<your-infura-project-id>
INFURA_IPFS_PROJECT_SECRET=<your-infura-project-secret>

# Or use Pinata: https://www.pinata.cloud/
PINATA_API_KEY=<your-pinata-api-key>
PINATA_API_SECRET=<your-pinata-secret-key>

# ===========================================
# AWS S3 (Optional - for file storage)
# ===========================================
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_REGION=us-east-1

# ===========================================
# PAYMENT APIs (Optional)
# ===========================================
# Get keys from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=<your-stripe-secret-key>

# Get key from https://commerce.coinbase.com/
COINBASE_COMMERCE_API_KEY=<your-coinbase-key>

# ===========================================
# OTHER APIs (Optional)
# ===========================================
# Get from https://platform.openai.com/
OPENAI_API_KEY=<your-openai-key>

# Get from https://sentry.io/
SENTRY_DSN=<your-sentry-dsn>

# ===========================================
# AUTH VERIFICATION APIs (Required for app to start)
# ===========================================
# These appear to be base64 encoded URLs - get valid API endpoints
AUTH_API_1=<your-first-auth-api-endpoint>
AUTH_API_2=<your-second-auth-api-endpoint>
